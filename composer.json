{
    "name": "sashalenz/monobank-api",
    "description": "This is my package monobank-api",
    "keywords": [
        "sashalenz",
        "laravel",
        "monobank-api"
    ],
    "homepage": "https://github.com/sashalenz/monobank-api",
    "license": "MIT",
    "authors": [
        {
            "name": "sashalenz",
            "email": "sashalenz@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^10.0||^11.0||^12.0||^13.0",
        "spatie/laravel-data": "^4.20",
        "spatie/laravel-package-tools": "^1.93"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "nunomaduro/collision": "^8.9",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^8.22.0||^9.0.0||^10.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Sashalenz\\MonobankApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sashalenz\\MonobankApi\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Sashalenz\\MonobankApi\\MonobankApiServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
